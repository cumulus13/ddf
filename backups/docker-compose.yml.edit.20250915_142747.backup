    container_name: archivist-es
    hostname: archivist-es
    environment:
    - ELASTIC_PASSWORD=Xxxnuxer13
    - ES_JAVA_OPTS=-Xms1g -Xmx1g
    - xpack.security.enabled=true
    - discovery.type=single-node
    - path.repo=/usr/share/elasticsearch/data/snapshot
    ulimits:
      memlock:
        soft: -1
        hard: -1
    volumes:
    - /containers/tubearchivist/elasticsearch/data:/usr/share/elasticsearch/data:rw
    expose:
    - '9200'
    - '9300'
    ports:
    - 9600:9200
    - 9700:9300
