    build:
      context: ./containers/nginx-proxy-manager
      dockerfile: Dockerfile
      network: host
    container_name: nginx-proxy-manager
    hostname: npm
    image: npm
    restart: unless-stopped
    ports:
    - 80:80
    - 443:443
    - 90:81
    environment:
      DB_MYSQL_HOST: mysql
      DB_MYSQL_PORT: 3306
      DB_MYSQL_USER: npm
      DB_MYSQL_PASSWORD: Xxxnuxer13
      DB_MYSQL_PASSWORD__FILE: /run/secrets/MYSQL_PWD
      DB_MYSQL_NAME: npm
    volumes:
    - /containers/nginx-proxy-manager/data:/data:rw
    - /containers/nginx-proxy-manager/letsencrypt:/etc/letsencrypt:rw
    secrets:
    - MYSQL_PASS
    depends_on:
    - mysql
    networks:
    - npm
    - default
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  caddy:
    build:
      context: ./containers/caddy
      dockerfile: Dockerfile
