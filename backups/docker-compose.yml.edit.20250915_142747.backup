    stdin_open: true
    cap_add:
    - SYS_ADMIN
    security_opt:
    - apparmor:unconfined
    network_mode: host
    environment:
    - DISPLAY=222.222.222.7:0.0
    - DBUS_SESSION_BUS_ADDRESS=unix:path=/var/run/dbus/system_bus_socket
