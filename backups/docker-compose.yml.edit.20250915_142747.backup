services:
  ubuntu-25.10-zsh-omz: &id001
    build:
      context: ./containers/ubuntu
      dockerfile: Dockerfile-ubuntu-25.10-zsh-omz
      network: host
      args:
        OMZ_REPO: http://gogs.container.com/root/ohmyzsh
        POWERLEVEL10K_REPO: http://gogs.container.com/root/powerlevel10k
        DISPLAY: 222.222.222.7:0.0
    image: ubuntu-25.10-zsh-omz
    container_name: ubuntu-25.10-zsh-omz
    hostname: ubuntu-25.10-zsh-omz
    tty: true
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  apt-cacher-ng:
    build:
      context: ./containers/ubuntu
      dockerfile: Dockerfile-apt-cacher-ng
      network: host
    image: apt-cacher-ng
    container_name: apt-cacher-ng
    hostname: apt-cacher-ng
    tty: true
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    ports:
    - 3142:3142
    volumes:
    - /containers/ubuntu/conf/apt-cacher-ng.conf:/etc/apt-cacher-ng/acng.conf:rw
    - /containers/ubuntu/var/cache/apt-cacher-ng:/var/cache/apt-cacher-ng:rw
    - /projects:/projects:rw
    - /projects2:/projects2:rw
  alpine-3.20-zsh-omz:
    build:
      context: ./containers/alpine
      dockerfile: Dockerfile-alpine-3.20-zsh-omz
      network: host
      args:
        OMZ_REPO: http://gogs.container.com/root/ohmyzsh
        POWERLEVEL10K_REPO: http://gogs.container.com/root/powerlevel10k
        DISPLAY: 222.222.222.7:0.0
    image: alpine-3.20-zsh-omz
    container_name: alpine-3.20-zsh-omz
    hostname: alpine-3.20-zsh-omz
    tty: true
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  base:
    build:
      context: ./containers/base-alpine
      dockerfile: Dockerfile
    image: base-alpine
    container_name: base-alpine
    hostname: base-alpine
    ports:
    - '24:22'
    - 2516:514/udp
    - 2516:514
    env_file:
    - ./.env
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  base-mini:
    build:
      context: ./containers/base-mini-alpine
      dockerfile: Dockerfile
    image: base-mini-alpine
    container_name: base-mini-alpine
    hostname: base-mini-alpine
    ports:
    - 9004:9000
    - 8514:514/udp
    - 8514:514
    env_file:
    - ./.env
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  base-rsyslog-debian-bullseye:
    build:
      context: ./containers/base-rsyslog-debian-bullseye
      dockerfile: Dockerfile
    image: base-rsyslog-debian-bullseye
    container_name: base-rsyslog-debian-bullseye
    hostname: base-rsyslog-debian-bullseye
    ports:
    - '30:22'
    - 6514:514/udp
    - 6514:514
    env_file:
    - .env
    volumes:
    - /mnt/c/PROJECTS:/projects
    - /mnt/c/PROJECTS/containers/base-rsyslog-debian-bullseye/conf/rsyslog.conf:/tmp/rsyslog.conf
    - /mnt/c/PROJECTS/containers/base-rsyslog-debian-bullseye/conf/rsyslog.d:/etc/rsyslog.d
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  base-webserver:
    build:
      context: ./containers/base-webserver
      dockerfile: Dockerfile
    image: base-webserver
    container_name: base-webserver
    depends_on:
    - base-mini
    hostname: base-webserver
    ports:
    - '29:22'
    - 3514:514/udp
    - 3514:514
    env_file:
    - ./.env
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  webserver:
    build:
      context: ./containers/webserver-alpine
      dockerfile: Dockerfile
    container_name: webserver
    image: webserver
    depends_on:
    - base-webserver
    hostname: webserver-alpine
    ports:
    - 80:80
    - 443:443
    - 9010:9001
    - 9000:9000
    - 9400:9100
    - 4514:514/udp
    - 4514:514
    volumes:
    - /mnt/c/PROJECTS:/projects:rw
    - /www:/www:reshared
    - /var/log:/log:rw
    - /containers/webserver:/webserver:rw
    - /containers/webserver/conf/nginx.conf:/etc/nginx/nginx.conf:rw
    - /containers/webserver/conf/vhosts:/etc/nginx/vhosts:rw
    - /containers/webserver/conf/proxies:/etc/nginx/proxies:rw
    - /containers/webserver/conf/keys:/etc/nginx/keys:rw
    - /containers/webserver/conf/streams:/etc/nginx/stream.d:rw
    - /containers/webserver/conf/stream.conf:/etc/nginx/conf.d/stream.conf:rw
    - /containers/webserver/conf/www.conf:/etc/php83/php-fpm.d/www.conf:rw
    - /containers/webserver/conf/index_php_info.php:/opt/www/phpinfo/index.php:rw
    - /containers/webserver/conf/create_user_www_data:/usr/bin/create_user_www_data:rw
    - /mnt/sdb2/MUSICS:/musics:rw
    - /mnt/c:/licx:rw
    env_file:
    - ./.env
    deploy:
      resources:
        limits:
          memory: 1024m
          cpus: '2.0'
    entrypoint:
    - /usr/local/bin/entrypoint.sh
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    networks:
    - default
    - cloud
  mysql:
    build:
      context: ./containers/mysql-alpine
      dockerfile: Dockerfile
    container_name: mysql
    image: mysql
    depends_on:
    - base-mini
    hostname: mysql
    ports:
    - 3306:3306
    - 5514:514/udp
    - 5514:514
    - 9015:9000
    volumes:
    - mysql_data:/var/lib/mysql
    env_file: ./.env
    deploy:
      resources:
        limits:
          memory: 1024m
          cpus: '2.0'
    command:
    - /usr/local/bin/entrypoint.sh
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  mysqle:
    build:
      context: ./containers/mysql-exporter
      dockerfile: Dockerfile
    container_name: mysqle
    image: mysqle
    depends_on:
    - base
    hostname: mysqle
    ports:
    - 9104:9104
    volumes:
    - /mnt/c/PROJECTS/containers/mysql-exporter/my.cf:/.my.cnf
    env_file: ./containers/mysql-exporter/.env
    deploy:
      resources:
        limits:
          memory: 100m
          cpus: '0.2'
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  mongo:
    build:
      context: ./containers/mongo-alpine
      dockerfile: Dockerfile1
    hostname: mongo
    container_name: mongo
    image: mongo
    depends_on:
    - base
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    ports:
    - 27017:27017
    - 9009:9000
    - 9514:514/udp
    volumes:
    - mongo-data:/data/db
    - mongo-config:/data/configdb
    - /mnt/c/PROJECTS/containers/mongo-alpine/rsyslog.conf:/tmp/rsyslog.conf
    env_file: ./.env
    environment:
      MONGO_INITDB_ROOT_USERNAME: admin
      MONGO_INITDB_ROOT_PASSWORD: admin
  rabbitmq:
    build:
      context: ./containers/rabbit
      dockerfile: Dockerfile1
    container_name: rabbitmq
    image: rabbitmq
    depends_on:
    - base-mini
    hostname: rabbitmq
    ports:
    - 5672:5672
    - 15672:15672
    - 9500:9100
    env_file:
    - ./.env
    deploy:
      resources:
        limits:
          memory: 512m
          cpus: '2.0'
    command:
    - /usr/local/bin/entrypoint.sh
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  rsyslog-alpine:
    build:
      context: ./containers/rsyslog-alpine
      dockerfile: Dockerfile
    hostname: rsyslog-alpine
    container_name: rsyslog-alpine
    image: rsyslog-alpine
    ports:
    - 514:514/udp
    - 514:514
    restart: unless-stopped
    volumes:
    - /mnt/c/LOGS:/log:rw
    env_file:
    - ./.env
    deploy:
      resources:
        limits:
          memory: 512m
          cpus: '2.0'
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  rsyslog:
    build:
      context: ./containers/rsyslog
      dockerfile: Dockerfile
    hostname: rsyslog
    container_name: rsyslog
    image: rsyslog
    ports:
    - 514:514/udp
    - 514:514
    volumes:
    - /mnt/c/LOGS:/log:rw
    - /mnt/c/PROJECTS/containers/rsyslog/conf/appliance:/home/appliance
    - /mnt/c/PROJECTS/containers/rsyslog/conf/config:/config
    - /mnt/c/PROJECTS/containers/rsyslog/conf/rsyslog.d:/etc/rsyslog.d
    - /mnt/c/PROJECTS/containers/rsyslog/conf/rsyslog.conf:/etc/rsyslog.conf
    env_file:
    - ./.env
    deploy:
      resources:
        limits:
          memory: 512m
          cpus: '2.0'
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  komodo-mongo:
    image: mongo
    hostname: mongo
    container_name: mongo
    labels:
      komodo.skip: null
    command: --quiet --wiredTigerCacheSizeGB 0.25
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    volumes:
    - mongo-data:/data/db
    - mongo-config:/data/configdb
    env_file: ./.env
  komodo:
    build:
      context: ./containers/komodo
      dockerfile: Dockerfile
    image: komodo
    hostname: komodo
    container_name: komodo
    labels:
      komodo.skip: null
    restart: unless-stopped
    depends_on:
    - base-rsyslog-debian-bullseye
    - mongo
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    ports:
    - 9120:9120
    - '30:22'
    - 6514:514/udp
    - 6514:514
    env_file: .env
    deploy:
      resources:
        limits:
          memory: 1000m
          cpus: '2.0'
    volumes:
    - repo-cache:/repo-cache
    - /mnt/c/PROJECTS:/projects
    - /mnt/c/PROJECTS/containers/base-rsyslog-debian-bullseye/conf/rsyslog.conf:/tmp/rsyslog.conf
    - /mnt/c/PROJECTS/containers/base-rsyslog-debian-bullseye/conf/rsyslog.d:/etc/rsyslog.d
  periphery:
    image: ghcr.io/mbecker20/periphery:${COMPOSE_KOMODO_IMAGE_TAG:-latest}
    hostname: periphery
    container_name: periphery
    labels:
      komodo.skip: null
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    env_file: ./.env
    volumes:
    - /var/run/docker.sock:/var/run/docker.sock
    - /proc:/proc
    - ${PERIPHERY_ROOT_DIRECTORY:-/etc/komodo}:${PERIPHERY_ROOT_DIRECTORY:-/etc/komodo}
  postgres:
    build:
      context: ./containers/postgres
      dockerfile: Dockerfile
    container_name: postgresql
    hostname: postgresql
    image: postgresql
    shm_size: 256m
    environment:
      POSTGRES_DB: postgres
      POSTGRES_USER: root
      POSTGRES_PASSWORD: Xxxnuxer13
    volumes:
    - /containers:/containers
    - pg_data:/var/lib/postgresql/data
    - /containers/postgres/pg_run:/run/postgresql
    ports:
    - 5432:5432
    - '31:22'
    - 9013:9000
    - 12514:514/udp
    healthcheck:
      test:
      - CMD
      - pg_isready
      - -U
      - postgres
      interval: 10s
      retries: 5
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  mysql2:
    build:
      context: ./containers/mysql
      dockerfile: Dockerfile
    container_name: mysql2
    hostname: mysql2
    image: mysql2
    env_file: ./.env
    volumes:
    - /mnt/c/PROJECTS:/projects
    - mysql_data:/var/lib/mysql
    ports:
    - 3306:3306
    - '38:22'
    command:
    - mysqld
    - --user=mysql
    - --console
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  pgadmin:
    build:
      context: ./containers/pgadmin
      dockerfile: Dockerfile
    container_name: pgadmin
    hostname: pgadmin
    image: pgadmin
    shm_size: 256m
    ports:
    - 5050:80
    - 5054:443
    - '34:22'
    depends_on:
    - postgres
    deploy:
      resources:
        limits:
          memory: 1024m
          cpus: '1.0'
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  odoo:
    build:
      context: ./containers/odoo
      dockerfile: Dockerfile
    container_name: odoo
    image: odoo
    depends_on:
    - postgres
    ports:
    - 8069:8069
    environment:
    - DB_HOST=postgres
    - DB_USER=odoo
    - DB_PASSWORD=Xxxnuxer13
    - DB_NAME=odoo
    volumes:
    - /mnt/c/PROJECTS:/projects
    - /mnt/c/PROJECTS/containers/odoo/odoo-18.0:/opt/odoo/odoo
    - odoo_data:/var/lib/odoo
    entrypoint:
    - /usr/local/bin/entrypoint.sh
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  pypiserver:
    container_name: pypiserver
    hostname: pypiserver
    image: pypiserver/pypiserver:latest
    ports:
    - 9111:8080
    volumes:
    - /mnt/c/PYTHON_MODULES:/data/packages
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    env_file:
    - ./.env
  pypiserver2:
    build:
      context: ./containers/pypiserver
      dockerfile: Dockerfile1
    container_name: pypiserver2
    hostname: pypiserver2
    image: pypiserver2
    ports:
    - 9222:8080
    - 9005:9000
    - 7514:514/udp
    - 7514:514
    volumes:
    - /mnt/c/PYTHON_MODULES:/data/packages
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    env_file:
    - ./.env
    deploy:
      resources:
        limits:
          memory: 200m
          cpus: '1.0'
  privatepypi:
    build:
      context: ./containers/privatepypi
      dockerfile: Dockerfile
    container_name: privatepypi
    hostname: privatepypi
    image: privatepypi
    ports:
    - 9333:8888
    - 9444:9444
    - 33000:32000
    - 9400:9100
    volumes:
    - /mnt/c/PROJECTS:/projects
    - /mnt/c/PYTHON_MODULES:/data/packages
    - /mnt/c/PROJECTS/containers/privatepypi/conf/pryvate.conf:/data/pryvate.conf
    - /mnt/c/PROJECTS/containers/privatepypi/conf/pryvate.secret:/data/pryvate.secret
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    env_file:
    - ./.env
  traefik:
    image: traefik:v2.1
    container_name: traefik
    hostname: traefik
    volumes:
    - /var/run/docker.sock:/var/run/docker.sock:ro
    - /mnt/traefik:/etc/traefik:ro
    - /mnt/traefik/acme:/etc/traefik/acme
    command:
    - --entrypoints.web.address=:80
    - --entrypoints.websecure.address=:443
    - --providers.docker=true
    - --providers.docker.exposedbydefault=false
    - --api.dashboard=true
    - --certificatesresolvers.leresolver.acme.email=cumulus13@gmail.com
    - --certificatesresolvers.leresolver.acme.storage=/etc/traefik/acme/acme.json
    - --certificatesresolvers.leresolver.acme.httpChallenge=true
    - --certificatesresolvers.leresolver.acme.httpChallenge.entrypoint=web
    ports:
    - 80:80
    - 443:443
    labels:
    - traefik.enable=true
    - traefik.http.routers.traefik.rule=Host(`cumulus13.com`) && (PathPrefix(`/api`)
      || PathPrefix(`/dashboard`))
    - traefik.http.routers.traefik.entrypoints=websecure
    - traefik.http.routers.traefik.tls=true
    - traefik.http.routers.traefik.tls.certresolver=leresolver
    - traefik.http.routers.traefik.service=api@internal
    - traefik.http.routers.traefik.middlewares=authtraefik
    - traefik.http.middlewares.authtraefik.basicauth.usersfile=/etc/traefik/usersfile
    - traefik.http.routers.http-catchall.rule=hostregexp(`{host:.+}`)
    - traefik.http.routers.http-catchall.entrypoints=web
    - traefik.http.routers.http-catchall.middlewares=redirect-to-https
    - traefik.http.middlewares.redirect-to-https.redirectscheme.scheme=https
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  laravel:
    build:
      context: ./containers/laravel
      dockerfile: Dockerfile
    container_name: laravel
    image: laravel
    hostname: laravel
    ports:
    - 8081:8000
    - 8082:8001
    - 8083:8002
    - 8084:8003
    - '33:22'
    working_dir: /var/www/html
    volumes:
    - /mnt/c/PROJECTS:/projects
    - laravel_data:/var/www/html
    entrypoint:
    - /usr/local/bin/entrypoint.sh
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  hoppscotch-frontend:
    build:
      context: ./containers/hoppscotch/frontend
      dockerfile: Dockerfile
    container_name: hoppscotch-frontend
    image: hoppscotch-frontend
    hostname: hoppscotch-frontend
    ports:
    - 20001:3000
    - '35:22'
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  hoppscotch-backend:
    build:
      context: ./containers/hoppscotch/backend
      dockerfile: Dockerfile
    container_name: hoppscotch-backend
    image: hoppscotch-backend
    hostname: hoppscotch-backend
    ports:
    - 20002:3170
    - '36:22'
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  hoppscotch-admin:
    build:
      context: ./containers/hoppscotch/admin
      dockerfile: Dockerfile
    container_name: hoppscotch-admin
    image: hoppscotch-admin
    hostname: hoppscotch-admin
    ports:
    - 20003:3100
    - '37:22'
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  mailserver:
    build:
      context: ./containers/mailserver
      dockerfile: Dockerfile1
    deploy:
      resources:
        limits:
          memory: 1024m
          cpus: '1.0'
    container_name: mailserver
    image: mailserver
    hostname: mailserver
    environment:
      MAIL_HOSTNAME: mail.licface.com
      MYSQL_USER: mail_admin
      MYSQL_PASSWORD: Xxxnuxer13
      MYSQL_HOST: mysql
      MYSQL_DATABASE: mailserver
      MYSQL_ROOT_PASSWORD: Xxxnuxer13
    ports:
    - '25:25'
    - 143:143
    - 465:465
    - 587:587
    - 993:993
    - 110:110
    - 11514:514/udp
    - 9012:9000
    - '27:22'
    volumes:
    - mail_data:/var/mail
    depends_on:
    - mysql
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
    restart: always
  roundcube:
    build:
      context: ./containers/roundcube
      dockerfile: Dockerfile
    container_name: roundcube
    image: roundcube
    hostname: roundcube
    restart: always
    environment:
    - ROUNDCUBEMAIL_DB_TYPE=postgres
    - ROUNDCUBEMAIL_DB_HOST=postgresql
    - ROUNDCUBEMAIL_DB_USER=mail_admin
    - ROUNDCUBEMAIL_DB_PASSWORD=Xxxnuxer13
    - ROUNDCUBEMAIL_DB_NAME=roundcube
    - ROUNDCUBEMAIL_DEFAULT_HOST=mailserver
    volumes:
    - /mnt/c/PROJECTS/containers/roundcube/conf/config.inc.php:/var/www/html/config/config.inc.php
    ports:
    - 32000:80
    depends_on:
    - postgres
    - mailserver
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
        tag: docker/{{.Name}}
  django:
    build:
      context: ./containers/django
      dockerfile: Dockerfile
    container_name: django
    image: django
    hostname: django
    volumes:
    - /mnt/c/PROJECTS:/projects
    ports:
    - '39:22'
    - 7000:7000
    - 7001:7001
    - 7002:7002
    - 7003:7003
    - 7004:7004
    - 7005:7005
    depends_on:
    - postgres
    deploy:
      resources:
        limits:
