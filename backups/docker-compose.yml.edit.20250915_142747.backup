    volumes:
    - /containers/var/cache/ntfy:/var/cache/ntfy
    - /containers/ntfy/etc/ntfy:/etc/ntfy
    ports:
    - 89:80
    healthcheck:
      test:
      - CMD-SHELL
      - wget -q --tries=1 http://localhost:80/v1/health -O - | grep -Eo '"healthy"\s*:\s*true'
        || exit 1
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 40s
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 100m
          cpus: '1.0'
    logging:
      driver: syslog
      options:
        syslog-address: udp://222.222.222.7:514
