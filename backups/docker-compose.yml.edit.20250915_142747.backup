    - TA_USERNAME=tube
    - TA_PASSWORD=Xxxnuxer13
    - ELASTIC_PASSWORD=Xxxnuxer13
    - TZ=Asia/Jakarta
    healthcheck:
      test:
      - CMD
      - curl
      - -f
      - http://localhost:8000/api/health
      interval: 2m
      timeout: 10s
      retries: 3
      start_period: 30s
    depends_on:
    - elasticsearch
    - redis
