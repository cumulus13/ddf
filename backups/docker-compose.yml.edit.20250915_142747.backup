    extra_hosts:
    - jackd:127.0.1.1
    tty: true
    privileged: true
    network_mode: host
    devices:
    - /dev/snd:/dev/snd
    tmpfs:
    - /run/user/1001:exec,mode=0700,uid=1001,gid=1001
    volumes:
    - /tmp/.X11-unix:/tmp/.X11-unix:ro
    - /var/run/dbus:/var/run/dbus:ro
    - /dev/snd:/dev/snd
    - /run/dbus:/run/dbus
    environment:
    - XDG_RUNTIME_DIR=/run/user/1001
    - PULSE_SERVER=unix:/run/user/1000/pulse/native
    cap_add:
    - SYS_PTRACE
    logging:
